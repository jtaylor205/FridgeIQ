MONGO_URI=mongodb://localhost:27017/fridgeiq
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
PORT=5000

# For food scanner (label/nutrition API - e.g. Open Food Facts, Nutritionix)
NUTRITION_API_KEY=your_key_here
NUTRITION_API_HOST=trackapi.nutritionix.com

# For expiration email reminders (e.g. SendGrid, Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_password_here
EMAIL_FROM=noreply@fridgeiq.com
